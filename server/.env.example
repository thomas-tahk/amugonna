# Database Configuration
# Local development: both vars point to the same local database
# Production (Neon): DATABASE_URL = pooled connection, DIRECT_URL = direct connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amugonna_dev"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/amugonna_dev"

# Authentication & Security
# Generate a strong, random secret for JWT token signing
# NEVER use the example value below in production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3001
NODE_ENV="development"

# CORS - comma-separated list of allowed frontend origins
# Leave unset in development (allows all origins)
# Production example: ALLOWED_ORIGINS=https://amugonna.vercel.app
# ALLOWED_ORIGINS=
